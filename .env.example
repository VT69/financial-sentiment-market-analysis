# ════════════════════════════════════════════════════════════════
# .env.example — Financial Data Pipeline API Keys
# ════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control!
#
# cp .env.example .env
#
# ════════════════════════════════════════════════════════════════


# ── SOURCE 2: FRED ───────────────────────────────────────────────
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
# Click "Request API Key" after creating a free account.
FRED_API_KEY=891f55aef63158096a05cae73dc3290b


# ── SOURCE 3: GDELT via Google BigQuery ──────────────────────────
# Steps:
#   1. Create a Google Cloud project: https://console.cloud.google.com
#   2. Enable BigQuery API in the project
#   3. Create a Service Account with "BigQuery Job User" + "BigQuery Data Viewer" roles
#   4. Download the service account JSON key file
#   5. Set this variable to the absolute path of that JSON file
#
# Note: GDELT queries in BigQuery may incur costs (~$5/TB scanned).
#       The pipeline queries month by month and caches results as parquet
#       to minimise repeated scanning.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp_service_account.json


# ── SOURCE 5: Alpha Vantage ──────────────────────────────────────
# Free API key (25 req/day, 5 req/min limit):
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here


# ── SOURCE 6: Reddit (PRAW) ──────────────────────────────────────
# Steps:
#   1. Log in at reddit.com
#   2. Go to: https://www.reddit.com/prefs/apps
#   3. Click "create another app..." → select "script"
#   4. Fill in name, description, redirect URI (http://localhost:8080)
#   5. Copy the client_id (under app name) and client_secret
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
# User agent should describe your app: platform:appname:version (by u/yourname)
REDDIT_USER_AGENT=script:financial-pipeline:v1.0 (by u/your_reddit_username)


# ── SOURCE 7: NewsAPI ────────────────────────────────────────────
# Free developer plan (100 req/day, 1 month article history):
# https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here


# ── SOURCE 8: Quandl / Nasdaq Data Link ──────────────────────────
# Free registration: https://data.nasdaq.com/sign-up
# Find your API key at: https://data.nasdaq.com/account/profile
QUANDL_API_KEY=your_quandl_api_key_here


# ════════════════════════════════════════════════════════════════
# Sources that do NOT need API keys:
#   SOURCE 1: yfinance     — no key required
#   SOURCE 4: Google Trends (pytrends) — no key required
# ════════════════════════════════════════════════════════════════
